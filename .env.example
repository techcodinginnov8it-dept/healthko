# ─────────────────────────────────────────────────────────────────
# HealthkO — Environment Variable Template
# Copy this file to .env.local for local development.
# Set these same keys in: Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────


# ─── Supabase ────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ─── Prisma / PostgreSQL (via Supabase) ──────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  → Transaction pooler  (port 6543) — used by Prisma Client at runtime
# DIRECT_URL    → Session pooler or direct (port 5432) — used by prisma db push / migrate

DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres


# ─── Session / Auth ──────────────────────────────────────────────
# Random 64-byte hex string used to sign HTTP-only session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

SESSION_SECRET=replace-with-a-64-byte-random-hex-string


# ─── App URL ─────────────────────────────────────────────────────
# Used in password-reset / email OTP redirect links.
# Set to your Vercel deployment URL in production (no trailing slash).

NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Server ──────────────────────────────────────────────────────
PORT=3000

# Optional HTTPS (local dev only — Vercel handles TLS automatically)
# HTTPS_PORT=3443
# HTTPS_PFX_PATH=./certs/healthko.pfx
# HTTPS_PFX_PASSPHRASE=your-pfx-passphrase


# ─── Resend (Email) ──────────────────────────────────────────────
# Uncomment when Resend email sending is wired up — https://resend.com/api-keys
# RESEND_API_KEY=re_your_resend_api_key
